{
  "meta": {
    "name": "HeroArc Design Tokens",
    "version": "1.0.0",
    "description": "Unified HeroArc token system — forest primary, teal marketing bridge"
  },
  "color": {
    "primitive": {
      "neutral-0": "#FFFFFF",
      "neutral-50": "#FAF6EE",
      "neutral-100": "#F0EBE0",
      "neutral-200": "#E2DDD2",
      "neutral-400": "#9A9488",
      "neutral-700": "#4A453C",
      "neutral-900": "#2C2820",
      "forest-100": "#E8F0EB",
      "forest-500": "#3D6B54",
      "forest-600": "#2F5542",
      "teal-100": "#E7F5F2",
      "teal-400": "#49B7A5",
      "teal-500": "#6BBF8A",
      "gold-100": "#FBF3DC",
      "gold-400": "#E8B84A",
      "sky-100": "#E8F4FA",
      "sky-400": "#7EB8DA",
      "mint-100": "#EAF6EF",
      "mint-300": "#A8D5BA",
      "coral-100": "#FBEAE4",
      "coral-400": "#E8927C",
      "salmon-300": "#F2B8A8",
      "peach-400": "#F7B267",
      "thread-base": "#E4DED4"
    },
    "semantic": {
      "background": "{color.primitive.neutral-50}",
      "surface": "{color.primitive.neutral-0}",
      "surfaceTint": "{color.primitive.neutral-100}",
      "border": "{color.primitive.neutral-200}",
      "primary": "{color.primitive.forest-500}",
      "primaryPressed": "{color.primitive.forest-600}",
      "primaryMuted": "{color.primitive.forest-100}",
      "accent": "{color.primitive.teal-400}",
      "accentMuted": "{color.primitive.teal-100}",
      "companion": "{color.primitive.sky-400}",
      "companionMuted": "{color.primitive.sky-100}",
      "success": "{color.primitive.mint-300}",
      "successMuted": "{color.primitive.mint-100}",
      "celebration": "{color.primitive.gold-400}",
      "celebrationMuted": "{color.primitive.gold-100}",
      "gentleAlert": "{color.primitive.coral-400}",
      "gentleAlertMuted": "{color.primitive.coral-100}",
      "warning": "{color.primitive.salmon-300}",
      "wager": "{color.primitive.peach-400}",
      "textPrimary": "{color.primitive.neutral-900}",
      "textSecondary": "{color.primitive.neutral-700}",
      "textMuted": "{color.primitive.neutral-400}",
      "textInverse": "{color.primitive.neutral-0}",
      "tabActive": "{color.primitive.forest-500}",
      "tabInactive": "{color.primitive.neutral-400}",
      "overlay": "rgba(44, 40, 32, 0.45)"
    }
  },
  "fontFamily": {
    "display": "Manrope",
    "body": "Inter"
  },
  "fontSize": {
    "xs": 12,
    "sm": 14,
    "base": 16,
    "lg": 20,
    "xl": 24,
    "2xl": 32,
    "3xl": 40
  },
  "fontWeight": {
    "regular": "400",
    "medium": "500",
    "semibold": "600",
    "bold": "700",
    "extrabold": "800"
  },
  "lineHeight": {
    "tight": 1.25,
    "snug": 1.35,
    "normal": 1.5,
    "relaxed": 1.625
  },
  "spacing": {
    "0": 0,
    "1": 4,
    "2": 8,
    "3": 12,
    "4": 16,
    "5": 20,
    "6": 24,
    "8": 32,
    "10": 40,
    "12": 48,
    "16": 64
  },
  "radius": {
    "sm": 8,
    "md": 16,
    "lg": 24,
    "xl": 28,
    "full": 9999
  },
  "elevation": {
    "none": "none",
    "sm": "0 2px 8px rgba(44, 40, 32, 0.06)",
    "md": "0 4px 24px rgba(44, 40, 32, 0.08)",
    "lg": "0 8px 32px rgba(44, 40, 32, 0.12)"
  },
  "motion": {
    "duration": {
      "fast": 150,
      "normal": 250,
      "slow": 400,
      "celebration": 600
    },
    "easing": {
      "standard": "cubic-bezier(0.4, 0, 0.2, 1)",
      "decelerate": "cubic-bezier(0, 0, 0.2, 1)",
      "delight": "cubic-bezier(0.34, 1.56, 0.64, 1)",
      "reduceMotion": "cubic-bezier(0, 0, 0.2, 1)"
    }
  },
  "layout": {
    "screenPaddingHorizontal": 16,
    "gutter": 8,
    "maxContentWidth": 390,
    "minTouchTarget": 48,
    "bottomNavHeight": 56,
    "headerHeight": 56
  },
  "accessibility": {
    "minBodyFontSize": 16,
    "minTouchTarget": 48,
    "contrastPairs": [
      { "foreground": "forest-500", "background": "neutral-50", "ratio": "AA" },
      { "foreground": "neutral-900", "background": "neutral-50", "ratio": "AAA" },
      { "foreground": "neutral-0", "background": "forest-500", "ratio": "AA" }
    ]
  }
}
